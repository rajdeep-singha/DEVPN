{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DeVPN",
  "version": "0.1.0",
  "identifier": "com.devpn.node",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "DeVPN",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": null,
        "sidebarImage": null,
        "installMode": "perMachine",
        "displayLanguageSelector": false
      },
      "wix": null
    },
    "category": "Utility",
    "shortDescription": "Decentralized VPN on Flare Network",
    "longDescription": "DeVPN is a decentralized VPN application that allows you to run a VPN node and earn FLR tokens, or connect to VPN nodes as a client using the Flare blockchain for payments."
  }
}
