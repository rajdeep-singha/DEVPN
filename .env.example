# Copy this file to .env and fill in your values
# cp .env.example .env

# ============================================
# REQUIRED: Your wallet private key
# ============================================
# Get from MetaMask: Settings → Show private key
# Format: WITHOUT 0x prefix
# Example: 1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef
PRIVATE_KEY=your_private_key_here_without_0x

# ============================================
# OPTIONAL: Existing Contract Addresses
# ============================================
# If you already deployed NodeRegistry, add its address here
# Otherwise leave empty to deploy a new one
NODE_REGISTRY_ADDRESS=

# If you have an old escrow contract (for reference)
OLD_ESCROW_ADDRESS=

# ============================================
# RPC URLs (Pre-configured for Flare Networks)
# ============================================
# Coston2 Testnet (Chain ID: 114)
COSTON2_RPC_URL=https://coston2-api.flare.network/ext/C/rpc

# Flare Mainnet (Chain ID: 14)
FLARE_RPC_URL=https://flare-api.flare.network/ext/C/rpc

# ============================================
# OPTIONAL: Etherscan API Key (for verification)
# ============================================
# Get from https://flare-explorer.flare.network/api-keys
ETHERSCAN_API_KEY=

# ============================================
# SECURITY NOTES
# ============================================
# 1. NEVER commit .env to git (already in .gitignore)
# 2. Use a dedicated wallet for deployment (not your main wallet)
# 3. Only fund with what you need for deployment
# 4. Backup your private key securely
